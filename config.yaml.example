approvals:
  mode: false
  timeout: 60
  cron_mode: deny
command_allowlist:
- script execution via -e/-c flag
- start gateway outside systemd (use 'systemctl --user restart hermes-gateway')
hooks:
  enabled: true
  hooks_dir: ~/.hermes/hooks
  pre_tool_use: []
  post_tool_use: []
  session_start: []
  stop: []
  shell_timeout: 30
  fail_open: true
hooks_auto_accept: false
diff_sandbox:
  enabled: true
  sandbox_dir: ~/.hermes/diff_sandbox
  track_write_file: true
  track_patch: true
  auto_cleanup_after_days: 7
  snapshot_enabled: true
sandbox:
  enabled: true
  mode: warn
  fs_isolation:
    enabled: true
    allowed_paths: []
    protected_files:
    - .env
    - .git-credentials
    - ~/.ssh/id_rsa
    - ~/.aws/credentials
    - ~/.hermes/config.yaml
  cmd_blocklist:
    enabled: true
    patterns:
    - rm\s+-rf\s+/
    - curl.*\|\s*bash
    - wget.*\|\s*sh
    - git\s+push\s+--force.*origin\s+(main|master)
  network_isolation:
    enabled: false
    trusted_domains:
    - github.com
    - api.github.com
    - pypi.org
    - '*.nousresearch.com'
agent_factory:
  enabled: true
  templates_dir: ~/.hermes/agent_templates
  default_model: deepseek-v4-pro
provider:
  router_enabled: true
  health_check_interval: 60
  max_fallback_attempts: 2
  prefer_cheap: false
  prefer_local: false
  providers:
