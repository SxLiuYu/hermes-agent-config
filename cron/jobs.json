    {
      "id": "43f149208f45",
      "name": "A\u80a1\u6bcf\u65e5\u589e\u91cf\u66f4\u65b0",
      "prompt": "\u6267\u884c A \u80a1\u65e5\u7ebf\u4e09\u8282\u70b9\u589e\u91cf\u66f4\u65b0\uff0c\u5b8c\u6210\u540e\u5408\u5e76\u5230\u4e3b\u5e93\u5e76\u6c47\u62a5\u7ed3\u679c\u3002\n\n**Step 1: \u4e09\u8282\u70b9\u5e76\u884c\u542f\u52a8**\uff08\u5168\u90e8\u540e\u53f0\u8fd0\u884c\uff09\uff1a\n```bash\n# \u963f\u91cc\u4e91\nssh root@123.57.107.21 \"cd /root/yuanfang-brain && nohup python3 -u fetch_incremental.py --node aliyun > output_v5/fetch_incr_aliyun.log 2>&1 &\"\n# \u65b0\u52a0\u5761\nssh ubuntu@43.134.39.26 \"cd /home/ubuntu/yuanfang-brain && nohup python3 -u fetch_incremental.py --node sg > output_v5/fetch_incr_sg.log 2>&1 &\"\n# Mac Mini \u672c\u5730\ncd ~/yuanfang-brain && nohup python3 -u fetch_incremental.py --node macmini > output_v5/fetch_incr_macmini.log 2>&1 &\n```\n\n**Step 2: \u7b49\u5f85\u5b8c\u6210**\uff08\u8f6e\u8be2\u5404\u8282\u70b9 DB\uff0c\u68c0\u67e5\u4eca\u5929\u65e5\u671f\u7684\u6570\u636e\u662f\u5426\u5df2\u5199\u5165\uff0c\u6700\u591a\u7b49 90 \u5206\u949f\uff09\uff1a\n```bash\n# \u68c0\u67e5\u963f\u91cc\u4e91\u4eca\u5929\u7684\u8bb0\u5f55\u6570\nssh root@123.57.107.21 \"sqlite3 /root/yuanfang-brain/output_v5/output_tx_aliyun.db \\\"SELECT COUNT(*) FROM daily_kline WHERE date='$(date +%Y-%m-%d)'\\\"\"\n# \u68c0\u67e5\u65b0\u52a0\u5761\nssh ubuntu@43.134.39.26 \"sqlite3 /home/ubuntu/yuanfang-brain/output_v5/output_tx_sg.db \\\"SELECT COUNT(*) FROM daily_kline WHERE date='$(date +%Y-%m-%d)'\\\"\"\n# \u68c0\u67e5 Mac Mini\nsqlite3 ~/yuanfang-brain/output_v5/output_tx_macmini.db \"SELECT COUNT(*) FROM daily_kline WHERE date='$(date +%Y-%m-%d)'\"\n```\n\u5982\u679c\u4eca\u5929\u975e\u4ea4\u6613\u65e5\uff08\u5468\u672b/\u5047\u65e5\uff09\uff0c\u811a\u672c\u4f1a\u81ea\u52a8\u62c9\u53d6\u6700\u8fd1\u4ea4\u6613\u65e5\uff0c\u7528\u4e0a\u5468\u4e94\u7684\u65e5\u671f\u68c0\u67e5\u3002\u6bcf 5 \u5206\u949f\u8f6e\u8be2\u4e00\u6b21\uff0c\u4e09\u8282\u70b9\u90fd\u6709\u6570\u636e > 0 \u5373\u4e3a\u5b8c\u6210\u3002\n\n**Step 3: \u5408\u5e76\u5230\u4e3b\u5e93**\uff1a\n```bash\ncd ~/yuanfang-brain && python3 << 'EOF'\nimport sqlite3, subprocess\n\nmaster_path = \"output_v5/a_stock_master.db\"\nnodes = {\n    \"aliyun\": (\"root@123.57.107.21\", \"/root/yuanfang-brain/output_v5/output_tx_aliyun.db\"),\n    \"sg\": (\"ubuntu@43.134.39.26\", \"/home/ubuntu/yuanfang-brain/output_v5/output_tx_sg.db\"),\n    \"macmini\": (\"local\", \"output_v5/output_tx_macmini.db\"),\n}\n\n# \u83b7\u53d6\u4eca\u5929\u65e5\u671f\nfrom datetime import datetime\ntoday = datetime.now().strftime(\"%Y-%m-%d\")\n# \u5982\u679c\u662f\u5468\u672b\uff0c\u627e\u4e0a\u5468\u4e94\nd = datetime.now()\nif d.weekday() >= 5:\n    d = d - timedelta(days=d.weekday()-4)\ntoday = d.strftime(\"%Y-%m-%d\")\n\nmaster = sqlite3.connect(master_path)\n\nfor name, (host, path) in nodes.items():\n    if host == \"local\":\n        src = sqlite3.connect(path)\n    else:\n        # scp \u5230\u672c\u5730\u4e34\u65f6\u6587\u4ef6\n        tmp = f\"/tmp/incr_{name}.db\"\n        subprocess.run([\"scp\", f\"{host}:{path}\", tmp], check=True)\n        src = sqlite3.connect(tmp)\n    \n    # \u53ea\u590d\u5236\u4eca\u5929\u7684\u8bb0\u5f55\n    rows = src.execute(\"SELECT * FROM daily_kline WHERE date = ?\", (today,)).fetchall()\n    for row in rows:\n        try:\n            master.execute(\"INSERT OR IGNORE INTO daily_kline VALUES(?,?,?,?,?,?,?,?,?,?,?,?,?)\", row)\n        except:\n            pass\n    master.commit()\n    print(f\"{name}: {len(rows)} \u6761\u65b0\u8bb0\u5f55 (date={today})\")\n    src.close()\n\n# \u7edf\u8ba1\ntotal = master.execute(\"SELECT COUNT(DISTINCT code) FROM daily_kline WHERE date = ?\", (today,)).fetchone()[0]\nprint(f\"\\n\u5408\u5e76\u5b8c\u6210: {today} \u5171 {total} \u53ea\u80a1\u7968\")\nmaster.close()\nEOF\n```\n\n**Step 4: \u6c47\u62a5**\uff1a\u8f93\u51fa\u672c\u65e5\u66f4\u65b0\u7ed3\u679c\uff0c\u5305\u62ec\uff1a\u5404\u8282\u70b9\u65b0\u8bb0\u5f55\u6570\u3001\u5408\u5e76\u540e\u4eca\u65e5\u8986\u76d6\u80a1\u7968\u6570\u3001\u4e0e\u524d\u4e00\u4ea4\u6613\u65e5\u5bf9\u6bd4\uff08\u589e/\u51cf\uff09\u3002\n\n\u26a0\ufe0f \u6ce8\u610f\uff1a\u5982\u679c\u4eca\u5929\u662f\u5468\u672b\u6216\u8282\u5047\u65e5\uff08\u811a\u672c\u4f1a\u81ea\u52a8\u8bc6\u522b\u5e76\u4f7f\u7528\u6700\u8fd1\u4ea4\u6613\u65e5\uff09\uff0c\u62a5\u544a\u4e2d\u6ce8\u660e\"\u975e\u4ea4\u6613\u65e5\uff0c\u5df2\u62c9\u53d6\u6700\u8fd1\u4ea4\u6613\u65e5 XXXX-XX-XX \u6570\u636e\"\u3002",
